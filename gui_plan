## `input.yaml` — complete field list

```yaml
# ============================================================
# LLZO Pipeline Input File
# Human-readable and editable. Generated by gui.py.
# Can also be edited by hand and run directly via:
#   python pipeline_runner.py --input input.yaml
# ============================================================

# -------------------- Structure --------------------
cif: "cubic-LLZO.cif"          # path to input CIF
supercell: [1, 1, 2]           # supercell expansion (x, y, z)

# -------------------- Dopants --------------------
# One entry per substitution. All must share the same carrier.
dopants:
  - dopant: "Nb"
    dopant_valency: 5
    host: "Zr"
    host_valency: 4
    count: 1
    carrier: "Li"
    carrier_valency: 1
  - dopant: "Y"
    dopant_valency: 3
    host: "La"
    host_valency: 3
    count: 1
    carrier: "Li"
    carrier_valency: 1

# -------------------- Distance Filters --------------------
# Set to null to disable any limit
distance_filters:
  dop_dop_min: null
  dop_dop_max: null
  dop_ion_min: null
  dop_ion_max: 15
  ion_ion_min: null
  ion_ion_max: null

# -------------------- Relaxation --------------------
max_files_per_folder: 1000
relax_model: 1          # 1-8, see 25_orb_v3_multi_folder_relax.py

# -------------------- MD --------------------
md_docker: false        # true = pass --docker to md_runner.sh
md_temperatures: [600, 800, 900, 1000, 1200]   # K, for dump file detection
md_dump_pattern: "dump*{T}*"   # {T} replaced with each temperature

# -------------------- RDF --------------------
run_rdf: true
rdf_pairs: "all"        # "all" or list e.g. ["1-1", "1-2"]
rdf_rmax: 10.0
rdf_dr: 0.05

# -------------------- Analysis --------------------
run_msd_arrhenius: true
run_elastic: true
run_trend_plots: true    # distance vs energy scatter
conductivity_t_ref: 300  # K, reference temperature for sigma
msd_fit_start: 100       # ps
msd_fit_end: 200         # ps
carrier_species: null    # null = auto-detect from CIF

# -------------------- Pipeline Stages --------------------
# Set false to skip a stage (useful for reruns)
stages:
  doping: true
  energy_comparison: true
  md: true
  post_processing: true
  rdf: true
  summary: true
```

